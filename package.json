{
  "name": "commonground",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/ui",
    "packages/config",
    "packages/types"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api dev:worker",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "cd apps/api && python3 -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:worker": "cd apps/api && python3 -m dramatiq app.worker.tasks --processes 1 --threads 4",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "cd apps/api && python3 -m compileall -q app",
    "lint": "npm-run-all --parallel lint:web lint:api",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "cd apps/api && ruff check app tests",
    "format": "npm-run-all --parallel format:web format:api",
    "format:web": "npm --workspace apps/web run format",
    "format:api": "cd apps/api && ruff format app tests",
    "test": "npm-run-all --parallel test:web test:api",
    "test:web": "npm --workspace apps/web run test",
    "test:api": "cd apps/api && pytest",
    "test:e2e": "npm --workspace apps/web run test:e2e",
    "seed": "cd apps/api && python3 -m app.scripts.seed",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write",
    "apps/api/**/*.py": [
      "ruff format",
      "ruff check --fix"
    ]
  }
}
